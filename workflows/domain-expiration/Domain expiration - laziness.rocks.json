      "name": "Fetch WHOIS Data",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [
        -224,
        160
      ],
      "id": "21f6cee2-a33f-48cf-af81-5353e2387a12",
