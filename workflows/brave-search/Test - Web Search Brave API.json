    {
      "parameters": {
        "jsCode": "const response = $input.item.json;\nconst records = Array.isArray(response.records) ? response.records : [];\n\nreturn {\n  json: {\n    status: response.status,\n    provider: response.provider,\n    query: response.query,\n    candidateCount: response.candidateCount,\n    recordCount: response.recordCount,\n    readerStats: response.metadata?.readerStats || {},\n    firstThreeResults: records.slice(0, 3).map((record) => ({\n      rank: record.rank,\n      title: record.title,\n      url: record.url,\n      description: record.description,\n      readerStatus: record.reader?.status || null,\n      contentChars: record.reader?.contentChars || 0,\n      contentPreview: record.reader?.content ? record.reader.content.slice(0, 500) : ''\n    })),\n    fullResponse: response\n  }\n};"
      },
